APP_NAME="ISC Quotation System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://iscquote.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u916348487_isc_qoute
DB_USERNAME=u916348487_isc_qoute
DB_PASSWORD="paste_hostinger_database_password_here"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.iscquote.com
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

CORS_ALLOWED_ORIGINS=https://iscquote.com,https://www.iscquote.com

JWT_TTL=120
JWT_REFRESH_TTL=1440
JWT_REMEMBER_REFRESH_TTL=43200

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@iscquote.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
